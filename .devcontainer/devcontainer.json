{
  "name": "Lunar3D",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "dev"
  },
  "remoteUser": "root",
  "workspaceFolder": "/workspace/lunar3d",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/lunar3d,type=bind,consistency=cached",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.makefile-tools",
        "vadimcn.vscode-lldb"
      ],
      "settings": {
        "files.associations": {
          "*.h": "c",
          "*.hpp": "cpp",
          "*.c": "c",
          "*.cpp": "cpp"
        },
        "makefile.configureOnOpen": true,
        "makefile.makePath": "make",
        "makefile.launchConfigurations": [],
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.configurationProvider": "ms-vscode.makefile-tools",
        "C_Cpp.default.includePath": [
          "${workspaceFolder}/source",
          "${workspaceFolder}/include",
          "${workspaceFolder}/external",
          "/opt/devkitpro/libctru/include",
          "/opt/devkitpro/portlibs/3ds/include"
        ],
        "C_Cpp.default.defines": [
          "__3DS__",
          "ARM11"
        ],
        "C_Cpp.default.compilerPath": "/opt/devkitpro/devkitARM/bin/arm-none-eabi-g++",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-arm"
      }
    }
  }
}
